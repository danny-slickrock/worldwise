# Worldwise — environment template. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored; this template is tracked. EXPO_PUBLIC_* vars are inlined
# into the client bundle, so only ever put public values here.

# Supabase project URL — Dashboard → Project Settings → Data API.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (NEW key format, starts with sb_publishable_).
# Dashboard → Project Settings → API Keys → Publishable key.
# This is a public client key — per-user isolation is enforced by RLS, not by
# hiding it. Never use the secret/service_role key in this file.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
